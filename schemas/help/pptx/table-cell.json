{
  "$schema": "../_schema.json",
  "format": "pptx",
  "element": "cell",
  "parent": "row",
  "operations": {
    "add": true,
    "set": true,
    "get": true,
    "query": true,
    "remove": true
  },
  "paths": {
    "positional": ["/slide[N]/table[M]/tr[R]/tc[C]"]
  },
  "note": "Appending a cell to a row is unusual — normally cells are seeded at row-Add time. This op exists for completeness.",
  "properties": {
    "text": {
      "type": "string",
      "description": "cell text content (single run).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop text=\"Hello\""],
      "readback": "concatenated run text",
      "enforcement": "strict"
    },
    "fill": {
      "type": "color",
      "description": "cell background fill. Accepts a solid color (hex, named, rgb(...)), 'none' for explicit no-fill, or a gradient string 'COLOR1-COLOR2[-ANGLE]' (e.g. 'FF0000-0000FF-90'). Stored as a:solidFill / a:gradFill / a:noFill on a:tcPr.",
      "aliases": ["background"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop fill=FFFF00", "--prop fill=#FF0000", "--prop fill=red", "--prop background=accent1", "--prop fill=none", "--prop fill=\"FF0000-0000FF-90\""],
      "readback": "#RRGGBB uppercase, 'gradient' (with separate 'gradient' key), or 'image' for picture fill",
      "enforcement": "report"
    },
    "border.all": {
      "type": "string",
      "description": "all four cell edges. Format: 'WIDTH[ DASH][ COLOR]' (e.g. '1pt solid FF0000') or 'STYLE;WIDTH;COLOR[;DASH]' (style ignored — kept for docx parity). DASH ∈ solid|dot|dash|lgDash|dashDot|sysDot|sysDash. Use 'none' to clear. Alias: border. Stored as a:lnL/lnR/lnT/lnB on a:tcPr.",
      "aliases": ["border"],
      "add": true, "set": true, "get": false,
      "examples": ["--prop border.all=\"1pt solid FF0000\"", "--prop border=none"],
      "readback": "split across border.top/bottom/left/right",
      "enforcement": "report"
    },
    "border.top": {
      "type": "string",
      "description": "top edge (a:lnT). Format same as border.all.",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.top=\"2pt solid 000000\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    },
    "border.bottom": {
      "type": "string",
      "description": "bottom edge (a:lnB).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.bottom=\"1pt solid 808080\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    },
    "border.left": {
      "type": "string",
      "description": "left edge (a:lnL).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.left=\"1pt solid 808080\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    },
    "border.right": {
      "type": "string",
      "description": "right edge (a:lnR).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.right=\"1pt solid 808080\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    },
    "border.tl2br": {
      "type": "string",
      "description": "diagonal from top-left to bottom-right (a:lnTlToBr).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.tl2br=\"1pt solid FF0000\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    },
    "border.tr2bl": {
      "type": "string",
      "description": "diagonal from top-right to bottom-left (a:lnBlToTr).",
      "add": true, "set": true, "get": true,
      "examples": ["--prop border.tr2bl=\"1pt solid FF0000\""],
      "readback": "WIDTH DASH COLOR",
      "enforcement": "report"
    }
  }
}
